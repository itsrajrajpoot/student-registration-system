@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4">

    <!-- Total Students -->
    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted">Total Students</h6>
                    <h3 class="fw-bold">@ViewBag.TotalStudents</h3>
                </div>
                <div style="font-size:28px;">🎓</div>
            </div>
        </div>
    </div>

    <!-- Active Students -->
    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted">Active Students</h6>
                    <h3 class="fw-bold text-success">@ViewBag.ActiveStudents</h3>
                </div>
                <div style="font-size:28px;">✅</div>
            </div>
        </div>
    </div>

    <!-- Inactive Students -->
    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted">Inactive Students</h6>
                    <h3 class="fw-bold text-danger">@ViewBag.InactiveStudents</h3>
                </div>
                <div style="font-size:28px;">⚠️</div>
            </div>
        </div>
    </div>

    <!-- Courses -->
    <div class="col-md-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted">Courses</h6>
                    <h3 class="fw-bold">@ViewBag.TotalCourses</h3>
                </div>
                <div style="font-size:28px;">📚</div>
            </div>
        </div>
    </div>

</div>