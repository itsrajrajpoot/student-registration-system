@using StudentRegistrationSystem.ViewModels
@model List<UserRoleViewModel>

@{
    ViewData["Title"] = "Manage Roles";
}

<h2 class="mb-4">Manage User Permissions</h2>

<div class="card shadow-sm border-0">

    <div class="card-body">

        <h5 class="mb-3">
            User: <strong>@ViewBag.UserName</strong>
        </h5>

        <form asp-action="ManageRoles" method="post">

            <input type="hidden" name="userId" value="@ViewBag.UserId" />

            <table class="table table-bordered align-middle">

                <thead class="table-light">
                    <tr>
                        <th>Permission</th>
                        <th class="text-center">Allow</th>
                    </tr>
                </thead>

                <tbody>

                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <tr>

                            <td>
                                @Model[i].RoleName
                                <input type="hidden" asp-for="@Model[i].RoleName" />
                            </td>

                            <td class="text-center">
                                <input type="checkbox"
                                       asp-for="@Model[i].IsSelected"
                                       class="form-check-input" />
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

            <button type="submit" class="btn btn-success">
                💾 Save Permissions
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                ⬅ Back
            </a>

        </form>

    </div>

</div>